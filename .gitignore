# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Markdown files
BUILD_PLAN.md
DESIGN.md
CLAUDE.md
AGENTS.md

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# extracted asset exports (local scratch, not part of the app)
/svg-exports/
/svg-exports.zip

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# exported hero data-card assets
hero-card-*.svg

# design-sync build output (regenerated by .ds-sync/ tools)
ds-bundle/
dist/
.ds-sync/.cache/
.ds-sync/node_modules/
